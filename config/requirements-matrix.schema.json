{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ahmadabdullayev.com/schemas/requirements-matrix.schema.json",
  "title": "SRS requirement applicability, dependency, and ownership matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "baseline_version",
    "effective_date",
    "source_documents",
    "page_reference_policy",
    "dependency_policy",
    "dependency_profiles",
    "requirements",
    "integrity"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "1.0.0" },
    "baseline_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "effective_date": { "type": "string", "format": "date" },
    "source_documents": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/sourceDocument" }
    },
    "page_reference_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "srs_card_start_page",
        "srs_toc_page",
        "backend_trace_page"
      ],
      "properties": {
        "model": { "$ref": "#/$defs/nonEmptyString" },
        "srs_card_start_page": { "$ref": "#/$defs/nonEmptyString" },
        "srs_toc_page": { "$ref": "#/$defs/nonEmptyString" },
        "backend_trace_page": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "dependency_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_rule",
        "explicit_requirement_ids_only",
        "unreferenced_edges_prohibited",
        "activation_precondition_template"
      ],
      "properties": {
        "source_rule": { "$ref": "#/$defs/nonEmptyString" },
        "explicit_requirement_ids_only": { "const": true },
        "unreferenced_edges_prohibited": { "const": true },
        "activation_precondition_template": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "dependency_profiles": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/dependencyProfile" }
    },
    "requirements": {
      "type": "array",
      "minItems": 264,
      "maxItems": 264,
      "items": { "$ref": "#/$defs/requirement" }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_count",
        "module_count",
        "dependency_profile_count",
        "explicit_requirement_dependency_edge_count",
        "priority_counts",
        "applicability_counts",
        "srs_toc_card_page_difference_count",
        "source_ledger_sha256",
        "decision_ledger_sha256"
      ],
      "properties": {
        "row_count": { "const": 264 },
        "module_count": { "const": 20 },
        "dependency_profile_count": { "const": 20 },
        "explicit_requirement_dependency_edge_count": {
          "type": "integer",
          "minimum": 0
        },
        "priority_counts": { "$ref": "#/$defs/counts" },
        "applicability_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["applicable", "not_applicable"],
          "properties": {
            "applicable": { "type": "integer", "minimum": 0 },
            "not_applicable": { "type": "integer", "minimum": 0 }
          }
        },
        "srs_toc_card_page_difference_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_ledger_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "decision_ledger_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "sourceDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "filename",
        "sha256",
        "pdf_page_count",
        "printed_page_reference",
        "matrix_role"
      ],
      "properties": {
        "id": { "enum": ["website-srs", "backend-specification"] },
        "filename": { "$ref": "#/$defs/nonEmptyString" },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "pdf_page_count": { "type": "integer", "minimum": 1 },
        "printed_page_reference": { "$ref": "#/$defs/nonEmptyString" },
        "matrix_role": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "dependencyProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "module", "source_preconditions", "source_refs"],
      "properties": {
        "id": { "type": "string", "pattern": "^DEP-[A-Z0-9]+$" },
        "module": { "$ref": "#/$defs/nonEmptyString" },
        "source_preconditions": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordinal",
        "id",
        "module",
        "title",
        "priority",
        "baseline_status",
        "normative_requirement",
        "source",
        "applicability",
        "dependencies",
        "ownership"
      ],
      "properties": {
        "ordinal": { "type": "integer", "minimum": 1, "maximum": 264 },
        "id": {
          "type": "string",
          "pattern": "^FR-[A-Z0-9]+-[0-9]{2}$"
        },
        "module": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "priority": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "obligation"],
          "properties": {
            "level": { "enum": ["P0", "P1", "P2"] },
            "obligation": { "enum": ["MUST", "SHOULD", "CONDITIONAL", "MAY"] }
          }
        },
        "baseline_status": { "$ref": "#/$defs/nonEmptyString" },
        "normative_requirement": { "$ref": "#/$defs/nonEmptyString" },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "srs_card_start_page",
            "srs_toc_page",
            "backend_trace_page",
            "backend_class"
          ],
          "properties": {
            "srs_card_start_page": {
              "type": "integer",
              "minimum": 15,
              "maximum": 310
            },
            "srs_toc_page": {
              "type": "integer",
              "minimum": 15,
              "maximum": 310
            },
            "backend_trace_page": {
              "type": "integer",
              "minimum": 38,
              "maximum": 63
            },
            "backend_class": {
              "enum": ["Direct backend", "Shared contract", "Frontend-led"]
            }
          }
        },
        "applicability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "basis", "condition", "rationale", "decision_refs"],
          "properties": {
            "state": { "enum": ["applicable", "not_applicable"] },
            "basis": {
              "enum": [
                "srs-priority-model",
                "full-build-profile",
                "activated-capability",
                "dormant-capability"
              ]
            },
            "condition": { "$ref": "#/$defs/nonEmptyString" },
            "rationale": { "$ref": "#/$defs/nonEmptyString" },
            "decision_refs": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/nonEmptyString" }
            }
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "profile_id",
            "activation_approval_precondition",
            "requirement_ids"
          ],
          "properties": {
            "profile_id": { "type": "string", "pattern": "^DEP-[A-Z0-9]+$" },
            "activation_approval_precondition": { "$ref": "#/$defs/nonEmptyString" },
            "requirement_ids": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^FR-[A-Z0-9]+-[0-9]{2}$"
              }
            }
          }
        },
        "ownership": {
          "type": "object",
          "additionalProperties": false,
          "required": ["accountable_roles", "assigned_person", "assignment_ref"],
          "properties": {
            "accountable_roles": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/nonEmptyString" }
            },
            "assigned_person": { "$ref": "#/$defs/nonEmptyString" },
            "assignment_ref": { "$ref": "#/$defs/nonEmptyString" }
          }
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["P0_MUST", "P1_SHOULD", "P2_CONDITIONAL", "P2_MAY"],
      "properties": {
        "P0_MUST": { "const": 148 },
        "P1_SHOULD": { "const": 62 },
        "P2_CONDITIONAL": { "const": 52 },
        "P2_MAY": { "const": 2 }
      }
    }
  }
}
