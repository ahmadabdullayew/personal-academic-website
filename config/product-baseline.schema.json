{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/product-baseline.schema.json",
  "title": "Personal academic website foundation product baseline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "baseline_version",
    "effective_date",
    "snapshot_status",
    "default_public_language",
    "source_documents",
    "owner",
    "approvers",
    "approval_policy",
    "ranking_method",
    "audiences",
    "visitor_goals",
    "owner_goals"
  ],
  "properties": {
    "baseline_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "effective_date": { "type": "string", "format": "date" },
    "snapshot_status": {
      "const": "owner-directed-foundation-public-snapshot"
    },
    "default_public_language": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "source_documents": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/sourceDocument" }
    },
    "owner": { "$ref": "#/$defs/owner" },
    "approvers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product",
        "content",
        "accessibility",
        "security",
        "privacy",
        "operations"
      ],
      "properties": {
        "product": { "$ref": "#/$defs/approver" },
        "content": { "$ref": "#/$defs/approver" },
        "accessibility": { "$ref": "#/$defs/approver" },
        "security": { "$ref": "#/$defs/approver" },
        "privacy": { "$ref": "#/$defs/approver" },
        "operations": { "$ref": "#/$defs/approver" }
      }
    },
    "approval_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicable_p0_waiver_allowed",
        "approval_by_silence",
        "conditional_features_default_enabled",
        "required_domains",
        "separate_role_records_required"
      ],
      "properties": {
        "applicable_p0_waiver_allowed": { "const": false },
        "approval_by_silence": { "const": false },
        "conditional_features_default_enabled": { "const": false },
        "required_domains": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "uniqueItems": true,
          "items": {
            "enum": [
              "product",
              "content",
              "accessibility",
              "security",
              "privacy",
              "operations"
            ]
          }
        },
        "separate_role_records_required": { "const": true }
      }
    },
    "ranking_method": { "$ref": "#/$defs/rankingMethod" },
    "audiences": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "secondary"],
      "properties": {
        "primary": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/audience" }
        },
        "secondary": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "$ref": "#/$defs/audience" }
        }
      }
    },
    "visitor_goals": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/goal" }
    },
    "owner_goals": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/goal" }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "evidenceReferences": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]+:.+"
      }
    },
    "sourceDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "filename", "sha256", "role", "page_reference_model"],
      "properties": {
        "id": {
          "enum": ["website-srs", "backend-specification"]
        },
        "filename": { "$ref": "#/$defs/nonEmptyString" },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "role": { "$ref": "#/$defs/nonEmptyString" },
        "page_reference_model": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_name",
        "represented_person",
        "final_decision_authority",
        "identification_basis",
        "unsupported_attributes_must_not_be_inferred"
      ],
      "properties": {
        "full_name": { "$ref": "#/$defs/nonEmptyString" },
        "represented_person": { "$ref": "#/$defs/nonEmptyString" },
        "final_decision_authority": { "const": true },
        "identification_basis": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "unsupported_attributes_must_not_be_inferred": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": [
              "academic_title",
              "biography",
              "degree",
              "discipline",
              "institutional_affiliation"
            ]
          }
        }
      }
    },
    "approver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "role", "evidence_refs"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "role": { "$ref": "#/$defs/nonEmptyString" },
        "evidence_refs": { "$ref": "#/$defs/evidenceReferences" }
      }
    },
    "rankingMethod": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "criteria_in_order",
        "tie_break_rule",
        "constraint_rule",
        "validation_status"
      ],
      "properties": {
        "method": { "$ref": "#/$defs/nonEmptyString" },
        "criteria_in_order": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "tie_break_rule": { "$ref": "#/$defs/nonEmptyString" },
        "constraint_rule": { "$ref": "#/$defs/nonEmptyString" },
        "validation_status": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "audience": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "definition", "rank", "evidence_refs"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "definition": { "$ref": "#/$defs/nonEmptyString" },
        "rank": { "type": "integer", "minimum": 1 },
        "evidence_refs": { "$ref": "#/$defs/evidenceReferences" }
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rank", "statement", "evidence_refs"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "rank": { "type": "integer", "minimum": 1 },
        "statement": { "$ref": "#/$defs/nonEmptyString" },
        "evidence_refs": { "$ref": "#/$defs/evidenceReferences" }
      }
    }
  }
}
