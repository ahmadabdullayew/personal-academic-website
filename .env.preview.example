# Deployment template only. Resolve every <...> value through managed configuration.
APP_ENV=preview
DJANGO_SETTINGS_MODULE=paw.settings.preview
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=<aws-secrets-manager-reference>
DJANGO_ALLOWED_HOSTS=pr-000.preview.ahmadabdullayev.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://pr-000.preview.ahmadabdullayev.com
SITE_BASE_URL=https://pr-000.preview.ahmadabdullayev.com
DATABASE_URL=<preview-postgresql-url-with-sslmode-verify-full>
DATABASE_POOL_MAX=5
AWS_REGION=eu-central-1
S3_ENDPOINT_URL=https://s3.eu-central-1.amazonaws.com
S3_BUCKET_QUARANTINE=<preview-quarantine-bucket>
S3_BUCKET_PRIVATE=<preview-private-bucket>
S3_BUCKET_PUBLIC=<preview-public-bucket>
SQS_ENDPOINT_URL=https://sqs.eu-central-1.amazonaws.com
SQS_QUEUE_URL=<preview-sqs-queue-url>
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en
CONTACT_DELIVERY_MODE=disabled
ORCID_ENABLED=false
CROSSREF_ENABLED=false
LOG_LEVEL=INFO
