# Safe local-development values. Copy this file to .env.local.
APP_ENV=development
DJANGO_SETTINGS_MODULE=paw.settings.development
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=development-only-change-me-before-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SITE_BASE_URL=http://localhost:8000

POSTGRES_DB=paw
POSTGRES_USER=paw
POSTGRES_PASSWORD=paw_development
DATABASE_URL=postgresql://paw:paw_development@127.0.0.1:5432/paw
DATABASE_POOL_MAX=10

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_ENDPOINT_URL=http://127.0.0.1:4566
S3_BUCKET_QUARANTINE=paw-quarantine-local
S3_BUCKET_PRIVATE=paw-private-local
S3_BUCKET_PUBLIC=paw-public-local
SQS_ENDPOINT_URL=http://127.0.0.1:4566
SQS_QUEUE_URL=http://127.0.0.1:4566/000000000000/paw-jobs-local

DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en
CONTACT_DELIVERY_MODE=disabled
ORCID_ENABLED=false
CROSSREF_ENABLED=false
LOG_LEVEL=INFO
