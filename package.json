{
  "name": "personal-academic-website-assets",
  "version": "0.1.0",
  "private": true,
  "description": "Strict TypeScript progressive enhancements and styles",
  "type": "module",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.23.0 <23",
    "npm": ">=10.9.8 <11"
  },
  "scripts": {
    "build": "vite build && touch src/static_dist/.gitkeep",
    "dev": "vite build --watch",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --max-warnings=0 && stylelint 'src/static_src/**/*.css'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
