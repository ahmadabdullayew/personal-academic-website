# Deployment template only. Resolve every <...> value through managed configuration.
APP_ENV=staging
DJANGO_SETTINGS_MODULE=paw.settings.staging
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=<aws-secrets-manager-reference>
DJANGO_ALLOWED_HOSTS=staging.ahmadabdullayev.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://staging.ahmadabdullayev.com
SITE_BASE_URL=https://staging.ahmadabdullayev.com
DATABASE_URL=<staging-postgresql-url-with-sslmode-verify-full>
DATABASE_POOL_MAX=10
AWS_REGION=eu-central-1
S3_ENDPOINT_URL=https://s3.eu-central-1.amazonaws.com
S3_BUCKET_QUARANTINE=<staging-quarantine-bucket>
S3_BUCKET_PRIVATE=<staging-private-bucket>
S3_BUCKET_PUBLIC=<staging-public-bucket>
SQS_ENDPOINT_URL=https://sqs.eu-central-1.amazonaws.com
SQS_QUEUE_URL=<staging-sqs-queue-url>
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en
CONTACT_DELIVERY_MODE=disabled
ORCID_ENABLED=false
CROSSREF_ENABLED=false
LOG_LEVEL=INFO
